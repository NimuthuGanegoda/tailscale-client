<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TailscaleClient.Views.VPNSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TailscaleClient.Assets"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="14,8,14,12">
            <TextBlock Text="VPN Configuration" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
            
            <!-- VPN Status Card -->
            <StackPanel
                Margin="0,0,0,8"
                CornerRadius="8"
                Padding="12,8,12,12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorSecondary}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VPN Status" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="VPNStatusText" Text="Not Connected" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    </StackPanel>
                    <Button x:Name="DisconnectButton" Grid.Column="1" Content="Disconnect" Click="DisconnectVPN_Click" IsEnabled="False" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Info Card -->
            <StackPanel
                Margin="0,0,0,8"
                CornerRadius="8"
                Padding="12,8,12,12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock TextWrapping="WrapWholeWords" Foreground="{ThemeResource TextFillColorSecondary}">
                    <Run Text="VPN support allows you to connect to external VPN services like VPNBook alongside your Tailscale network. "/>
                    <Run Text="Visit "/>
                    <Hyperlink NavigateUri="https://www.vpnbook.com/">vpnbook.com</Hyperlink>
                    <Run Text=" to get the latest credentials and server information."/>
                </TextBlock>
            </StackPanel>

            <!-- VPN Configurations List -->
            <TextBlock Text="Available VPN Servers" FontWeight="SemiBold" Margin="0,8,0,8"/>
            
            <ListView x:Name="VPNListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:VPNConfigItem">
                        <Grid Margin="0,4,0,4" Padding="12,8,12,8" CornerRadius="8" 
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ServerAddress}" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="12"/>
                                <TextBlock Text="{x:Bind ProtocolText}" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="12"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Edit" Click="EditVPN_Click" Tag="{x:Bind Index}"/>
                                <Button Content="Connect" Click="ConnectVPN_Click" Tag="{x:Bind Index}" Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Add New VPN Button -->
            <Button Content="Add VPN Configuration" Margin="0,12,0,0" Click="AddVPN_Click" HorizontalAlignment="Stretch"/>
        </StackPanel>
    </ScrollViewer>
</Page>
